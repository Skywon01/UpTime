{% extends 'base.html.twig' %}

{% block title %}Edition pièce{% endblock %}

{% block body %}
    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_part_index') }}">Stock</a></li>
                <li class="breadcrumb-item active">Édition {{ part.designation }}</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h1 class="h4 mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Modifier la pièce</h1>
                        {{ include('part/_delete_form.html.twig') }}
                    </div>
                    <div class="card-body p-4">
                        {{ include('part/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

                        <hr class="my-4">

                        <div class="d-flex justify-content-start">
                            <a href="{{ path('app_part_index') }}" class="btn btn-link text-muted">
                                <i class="bi bi-arrow-left"></i> Annuler et revenir au stock
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
