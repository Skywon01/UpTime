{% extends 'base.html.twig' %}

{% block title %}Détails Pièce : {{ part.designation }}{% endblock %}

{% block body %}
    <div class="container-fluid mt-4" style="max-width: 1000px;">
        {# Fil d'ariane #}
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a href="{{ path('app_part_index') }}">Inventaire</a></li>
                <li class="breadcrumb-item active">{{ part.reference }}</li>
            </ol>
        </nav>

        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="h2 mb-1 fw-bold text-dark">{{ part.designation }}</h1>
                <span class="badge bg-light text-muted border">REF: {{ part.reference }}</span>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('app_part_edit', {id: part.id}) }}" class="btn btn-warning shadow-sm">
                    <i class="bi bi-pencil me-1"></i> Modifier
                </a>
                {{ include('part/_delete_form.html.twig') }}
            </div>
        </div>

        <div class="row g-4">
            {# --- COLONNE GAUCHE : INFOS --- #}
            <div class="col-md-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-4 text-primary">Informations techniques</h5>
                        <div class="row mb-3">
                            <div class="col-sm-4 text-muted">Prix d'achat unitaire</div>
                            <div class="col-sm-8 fw-bold">{{ part.price|number_format(2, ',', ' ') }} € HT</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-4 text-muted">Fournisseur</div>
                            <div class="col-sm-8">
                                {% if part.supplier %}
                                    <a href="{{ path('app_supplier_show', {id: part.supplier.id}) }}" class="text-decoration-none">
                                        <i class="bi bi-truck me-1"></i> {{ part.supplier.name }}
                                    </a>
                                {% else %}
                                    <span class="text-danger small"><i class="bi bi-exclamation-triangle"></i> Aucun fournisseur lié</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title mb-3 text-primary">Compatibilité Machines</h5>
                        <div class="d-flex flex-wrap gap-2">
                            {% for machine in part.machines %}
                                <a href="{{ path('app_machine_show', {id: machine.id}) }}" class="badge bg-primary-subtle text-primary text-decoration-none p-2">
                                    <i class="bi bi-cpu me-1"></i> {{ machine.name }}
                                </a>
                            {% else %}
                                <span class="text-muted small">Aucune machine spécifiée.</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            {# --- COLONNE DROITE : STOCK --- #}
            <div class="col-md-4">
                <div class="card shadow-sm border-0 {{ part.stockQuantity <= 5 ? 'bg-warning-subtle' : 'bg-success-subtle' }} mb-4">
                    <div class="card-body text-center py-4">
                        <div class="text-uppercase small fw-bold mb-2">État du Stock</div>
                        <div class="display-4 fw-bold mb-1">{{ part.stockQuantity }}</div>
                        <div class="text-muted">unités disponibles</div>

                        {% if part.stockQuantity <= 0 %}
                            <div class="mt-3 badge bg-danger p-2 d-block">RUPTURE DE STOCK</div>
                        {% elseif part.stockQuantity <= 5 %}
                            <div class="mt-3 badge bg-warning text-dark p-2 d-block">STOCK FAIBLE</div>
                        {% endif %}
                    </div>
                </div>

                <a href="{{ path('app_part_index') }}" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i> Retour à l'inventaire
                </a>
            </div>
        </div>
    </div>
{% endblock %}
