{% extends 'base.html.twig' %}

{% block title %}Historique des Interventions{% endblock %}

{% block body %}
    <div class="container-fluid mt-4">
        {# --- HEADER --- #}
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h1 class="h3 mb-0 text-gray-800">
                <i class="bi bi-clock-history text-primary me-2"></i>
                {% if selectedMachine %}
                    Historique : <span class="text-primary">{{ selectedMachine.name }}</span>
                {% else %}
                    Toutes les interventions
                {% endif %}
            </h1>

            <div class="d-flex gap-2">
                {% if selectedMachine or currentStatus or currentType %}
                    <a href="{{ path('app_intervention_index') }}" class="btn btn-outline-secondary shadow-sm">
                        <i class="bi bi-arrow-left-short"></i> Voir tout
                    </a>
                {% endif %}
                <a href="{{ path('app_intervention_new', selectedMachine ? {'machine': selectedMachine.id} : {}) }}" class="btn btn-primary shadow-sm">
                    <i class="bi bi-plus-lg"></i> Nouvelle intervention
                </a>
            </div>
        </div>

        {# --- BARRE DE FILTRES --- #}
        <div class="card shadow-sm border-0 mb-4 bg-white">
            <div class="card-body d-flex flex-wrap align-items-center gap-3">
                <div class="small fw-bold text-muted text-uppercase"><i class="bi bi-funnel"></i> Filtres :</div>

                {# --- Groupe Statut --- #}
                <div class="btn-group">
                    <a href="{{ path('app_intervention_index', app.request.query.all|merge({'status': null})) }}"
                       class="btn btn-sm {{ currentStatus is empty ? 'btn-dark' : 'btn-outline-secondary' }}">Tous</a>
                    <a href="{{ path('app_intervention_index', app.request.query.all|merge({'status': 'active'})) }}"
                       class="btn btn-sm {{ currentStatus == 'active' ? 'btn-warning' : 'btn-outline-secondary' }}">En cours</a>
                    <a href="{{ path('app_intervention_index', app.request.query.all|merge({'status': 'finished'})) }}"
                       class="btn btn-sm {{ currentStatus == 'finished' ? 'btn-success' : 'btn-outline-secondary' }}">Terminés</a>
                </div>

                {# --- Groupe Type --- #}
                <div class="btn-group">
                    <a href="{{ path('app_intervention_index', app.request.query.all|merge({'type': null})) }}"
                       class="btn btn-sm {{ currentType is empty ? 'btn-dark' : 'btn-outline-secondary' }}">Tous types</a>
                    <a href="{{ path('app_intervention_index', app.request.query.all|merge({'type': 'Correctif'})) }}"
                       class="btn btn-sm {{ currentType == 'Correctif' ? 'btn-secondary' : 'btn-outline-secondary' }}">🛠️ Correctif</a>
                    <a href="{{ path('app_intervention_index', app.request.query.all|merge({'type': 'Préventif'})) }}"
                       class="btn btn-sm {{ currentType == 'Préventif' ? 'btn-info text-white' : 'btn-outline-secondary' }}">📅 Préventif</a>
                </div>

                {# --- Badge Machine Actuelle (si filtré) --- #}
                {% if selectedMachine %}
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                        Machine : {{ selectedMachine.name }}
                        <a href="{{ path('app_intervention_index', app.request.query.all|filter((v, k) => k != 'machine')) }}" class="text-primary ms-2"><i class="bi bi-x-circle-fill"></i></a>
                    </span>
                {% endif %}
            </div>
        </div>

        {# --- VERSION DESKTOP --- #}
        <div class="d-none d-md-block card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted text-uppercase small">
                    <tr>
                        <th class="ps-4">Machine</th>
                        <th>Type</th>
                        <th>Désignation</th>
                        <th>Date</th>
                        <th class="text-center">Coût</th>
                        <th class="text-center">Statut / Durée</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for intervention in interventions %}
                        <tr>
                            <td class="ps-4">
                                <a href="{{ path('app_intervention_index', app.request.query.all|merge({'machine': intervention.machine.id})) }}" class="text-decoration-none">
                                    <span class="badge bg-light text-primary border px-2 py-2" title="Isoler cette machine">
                                        <i class="bi bi-cpu me-1"></i> {{ intervention.machine.name|default('N/A') }}
                                    </span>
                                </a>
                            </td>
                            <td>
                                {% if intervention.type == 'Préventif' %}
                                    <span class="text-info small fw-bold"><i class="bi bi-calendar-check me-1"></i> Préventif</span>
                                {% else %}
                                    <span class="text-secondary small fw-bold"><i class="bi bi-tools me-1"></i> Correctif</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="fw-bold">{{ intervention.title }}</div>
                                <small class="text-muted d-block text-truncate" style="max-width: 200px;">{{ intervention.description|slice(0, 50) }}...</small>
                            </td>
                            <td class="small text-muted">
                                {{ intervention.createdAt|date('d/m/Y H:i') }}
                            </td>
                            <td class="text-center fw-bold text-success">
                                {{ intervention.TotalPartsCost|number_format(2, ',', ' ') }} €
                            </td>
                            <td class="text-center">
                                {% if intervention.endedAt %}
                                    {% set diff = intervention.endedAt.diff(intervention.createdAt) %}
                                    <span class="badge bg-light text-dark border shadow-sm">
                                        <i class="bi bi-clock-history me-1"></i> {{ diff.h }}h{{ diff.i }}
                                    </span>
                                {% else %}
                                    <span class="badge bg-warning text-dark animate-pulse">
                                        <i class="bi bi-play-circle-fill me-1"></i> En cours
                                    </span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="{{ path('app_intervention_show', {'id': intervention.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                                    <a href="{{ path('app_intervention_edit', {'id': intervention.id}) }}" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# --- VERSION MOBILE --- #}
        <div class="d-md-none">
            {# ... (ta logique mobile est déjà très bien, pense juste à ajouter le type si besoin) ... #}
        </div>
    </div>
{% endblock %}
