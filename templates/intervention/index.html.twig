{% extends 'base.html.twig' %}

{% block title %}Historique des Interventions{% endblock %}

{% block body %}
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h1 class="h3 mb-0"><i class="bi bi-tools text-primary me-2"></i>Historique des Interventions</h1>
            <a href="{{ path('app_intervention_new') }}" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg"></i> Nouvelle intervention
            </a>
        </div>

        {# --- VERSION DESKTOP --- #}
        <div class="d-none d-md-block card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted text-uppercase small">
                    <tr>
                        <th class="ps-4">Machine</th>
                        <th>Désignation de l'intervention</th>
                        <th>Date de création</th>
                        <th class="text-center">Coût Pièces</th>
                        <th class="text-center">Statut / Durée</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for intervention in interventions %}
                        <tr>
                            <td class="ps-4">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                                <i class="bi bi-cpu me-1"></i> {{ intervention.machine ? intervention.machine.name : 'N/A' }}
                            </span>
                            </td>
                            <td>
                                <div class="fw-bold">{{ intervention.title }}</div>
                                <small class="text-muted d-block text-truncate" style="max-width: 250px;">{{ intervention.description|slice(0, 50) }}...</small>
                            </td>
                            <td class="small text-muted">
                                <i class="bi bi-calendar3 me-1"></i> {{ intervention.createdAt ? intervention.createdAt|date('d/m/Y H:i') : '' }}
                            </td>
                            <td class="text-center fw-bold text-success">
                                {{ intervention.TotalPartsCost|number_format(2, ',', ' ') }} €
                            </td>
                            <td class="text-center">
                                {% if intervention.endedAt %}
                                    {% set diff = intervention.endedAt.diff(intervention.createdAt) %}
                                    <span class="badge bg-light text-dark border shadow-sm">
                                    <i class="bi bi-clock-history me-1"></i> {{ diff.h }}h {{ diff.i }}min
                                </span>
                                {% else %}
                                    <span class="badge bg-warning text-dark animate-pulse">
                                    <i class="bi bi-play-circle-fill me-1"></i> En cours
                                </span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="{{ path('app_intervention_show', {'id': intervention.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_intervention_edit', {'id': intervention.id}) }}" class="btn btn-sm btn-outline-warning" title="Éditer">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# --- VERSION MOBILE : CARDS --- #}
        <div class="d-md-none">
            {% for intervention in interventions %}
                <div class="card mb-3 shadow-sm border-0 border-start border-4 {{ intervention.endedAt ? 'border-success' : 'border-warning' }}">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary-subtle text-primary">{{ intervention.machine ? intervention.machine.name : 'N/A' }}</span>
                            {% if intervention.endedAt %}
                                <small class="text-muted"><i class="bi bi-check-circle text-success"></i> Terminé</small>
                            {% else %}
                                <span class="badge bg-warning text-dark">En cours</span>
                            {% endif %}
                        </div>

                        <h5 class="card-title h6 fw-bold mb-1">{{ intervention.title }}</h5>
                        <div class="small text-muted mb-3"><i class="bi bi-calendar3"></i> {{ intervention.createdAt|date('d/m/Y') }}</div>

                        <div class="d-flex justify-content-between align-items-center bg-light p-2 rounded">
                            <span class="small fw-bold text-success">{{ intervention.TotalPartsCost|number_format(2, ',', ' ') }} €</span>
                            <div class="btn-group">
                                <a href="{{ path('app_intervention_show', {'id': intervention.id}) }}" class="btn btn-sm btn-primary">Voir</a>
                                <a href="{{ path('app_intervention_edit', {'id': intervention.id}) }}" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="bi bi-tools fs-1 text-muted"></i>
                    <p class="mt-3">Aucune intervention enregistrée.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <style>
        /* Petite animation subtile pour l'indicateur "En cours" */
        .animate-pulse {
            animation: pulse-red 2s infinite;
        }
        @keyframes pulse-red {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.8; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
{% endblock %}
