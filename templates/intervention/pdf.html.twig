<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: sans-serif; font-size: 12px; color: #333; }
        .header { border-bottom: 2px solid #3b82f6; padding-bottom: 10px; margin-bottom: 20px; }
        .company-name { font-size: 20px; font-weight: bold; color: #1e293b; }
        .title { text-align: center; font-size: 18px; margin: 20px 0; text-transform: uppercase; }
        .section { margin-bottom: 20px; }
        .section-title { background: #f1f5f9; padding: 5px; font-weight: bold; border-left: 4px solid #3b82f6; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #e2e8f0; padding: 8px; text-align: left; }
        th { background: #f8fafc; }
        .footer { position: fixed; bottom: 0; width: 100%; text-align: center; font-size: 10px; color: #94a3b8; }
    </style>
</head>
<body>
<div class="header">
    <div class="company-name">⚓ UpTime - {{ intervention.machine.company.name }}</div>
    <div>Date d'édition : {{ "now"|date("d/m/Y H:i") }}</div>
</div>

<div class="title">Bon d'intervention #{{ intervention.id }}</div>

<div class="section">
    <div class="section-title">Informations Machine</div>
    <table>
        <tr>
            <th>Machine</th>
            <td>{{ intervention.machine.name }} ({{ intervention.machine.brand }})</td>
        </tr>
        <tr>
            <th>N° de Série</th>
            <td>{{ intervention.machine.serialNumber }}</td>
        </tr>
    </table>
</div>

<div class="section">
    <div class="section-title">Détails de l'Intervention</div>
    <table>
        <tr>
            <th>Description</th>
            <td>{{ intervention.description }}</td>
        </tr>
        <tr>
            <th>Statut</th>
            <td>{{ intervention.endedAt ? 'Terminée le ' ~ intervention.endedAt|date('d/m/Y') : 'En cours' }}</td>
        </tr>
    </table>
</div>

<div class="section">
    <div class="section-title">Pièces Détachées Utilisées</div>
    <table>
        <thead>
        <tr>
            <th>Référence</th>
            <th>Désignation</th>
            <th>Quantité</th>
        </tr>
        </thead>
        <tbody>
        {# Imaginons que tu as une relation ManyToMany ou une entité pivot #}
        {% for item in intervention.interventionConsumedParts %}
            <tr>
                <td>{{ item.part.reference }}</td>
                <td>{{ item.part.designation }}</td>
                <td>{{ item.quantity }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" style="text-align: center; color: #94a3b8;">Aucune pièce utilisée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<table style="border: none; margin-top: 50px;">
    <tr>
        <td style="border: none; width: 50%;">
            <strong>Signature Technicien</strong><br>
            <div style="border: 1px solid #ccc; height: 80px; margin-top: 10px; width: 200px;"></div>
        </td>
        <td style="border: none; width: 50%;">
            <strong>Signature Client (Bon pour accord)</strong><br>
            <div style="border: 1px solid #ccc; height: 80px; margin-top: 10px; width: 200px;"></div>
        </td>
    </tr>
</table>

{# On pourra ajouter les pièces détachées ici plus tard #}

<div class="footer">
    UpTime GMAO - Document généré numériquement - Page 1/1
</div>
</body>
</html>
