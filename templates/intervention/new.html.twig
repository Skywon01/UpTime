{# templates/intervention/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Nouvelle Intervention{% endblock %}

{% block body %}
    <div class="container mt-4">
        {# Fil d'ariane adapté au workflow de maintenance #}
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-light p-2 rounded shadow-sm small">
                <li class="breadcrumb-item"><a href="{{ path('app_intervention_index') }}">Interventions</a></li>
                <li class="breadcrumb-item active text-primary fw-bold">Rapport d'intervention</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-lg-9 mx-auto"> {# Un peu plus large pour les formulaires d'intervention souvent denses #}
                <div class="card shadow border-0">
                    <div class="card-header bg-primary text-white py-3">
                        <h1 class="h4 mb-0 fw-bold">
                            <i class="bi bi-tools me-2"></i>Ouvrir un nouveau rapport d'intervention
                        </h1>
                    </div>

                    <div class="card-body p-4">
                        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center mb-4 small">
                            <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                            <div>
                                Remplissez les détails de la panne ou de la maintenance préventive.
                                <strong>Pensez à bien renseigner le temps passé pour le calcul du coût machine.</strong>
                            </div>
                        </div>

                        {# Inclusion du formulaire #}
                        {{ include('intervention/_form.html.twig', {'button_label': 'Enregistrer l\'intervention'}) }}

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a href="{{ path('app_intervention_index') }}" class="btn btn-link text-muted text-decoration-none">
                                <i class="bi bi-arrow-left"></i> Annuler et voir la liste
                            </a>
                            <span class="badge bg-light text-dark border">Brouillon auto-sauvegardé</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
