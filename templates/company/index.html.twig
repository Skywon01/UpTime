{% extends 'base.html.twig' %}

{% block title %}Gestion des Entreprises (GOD Mode){% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1 text-gray-800"><i class="bi bi-shield-lock-fill text-danger me-2"></i>Administration Plateforme</h1>
                <p class="text-muted small mb-0">Gestion multi-entreprises et onboarding clients.</p>
            </div>

            {# Le bouton est désormais toujours accessible pour le GOD #}
            <a href="{{ path('app_company_new') }}" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Nouvelle Entreprise
            </a>
        </div>

        <div class="row">
            {% for company in companies %}
                <div class="col-xl-6">
                    <div class="card shadow-sm border-0 border-start border-primary border-4 mb-4">
                        <div class="card-body p-4">
                            {# HEADER DE LA CARD #}
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px; border: 1px dashed #dee2e6;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                    <div>
                                        <h2 class="h4 fw-bold mb-0">{{ company.name }}</h2>
                                        <span class="badge bg-info-subtle text-info small border border-info-subtle">Client ID: #{{ company.id }}</span>
                                    </div>
                                </div>
                                <div class="btn-group shadow-sm">
                                    <a href="{{ path('app_company_show', {'id': company.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir les détails">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_company_edit', {'id': company.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier la structure">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </div>

                            <hr>

                            {# NOUVEAU : STATS D'ACTIVITÉ (Vital pour le GOD) #}
                            <div class="row text-center mb-3">
                                <div class="col-4">
                                    <div class="p-2 border rounded bg-light">
                                        <small class="text-muted d-block">Machines</small>
                                        <span class="fw-bold">{{ company.machines|length }}</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="p-2 border rounded bg-light">
                                        <small class="text-muted d-block">Users</small>
                                        <span class="fw-bold text-primary">{{ company.users|length }}</span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="p-2 border rounded bg-light">
                                        <small class="text-muted d-block">Interventions</small>
                                        {# Ici on suppose que tu as la relation bidirectionnelle dans Company #}
                                        <span class="fw-bold">{{ company.interventions|default('0')|length }}</span>
                                    </div>
                                </div>
                            </div>

                            {# BLOC COORDONNÉES #}
                            <div class="row mb-2">
                                <div class="col-12 mb-1">
                                    <i class="bi bi-geo-alt text-muted me-2"></i>
                                    <span class="small">{{ company.address|default('Non renseignée') }}</span>
                                </div>
                                <div class="col-md-6 mb-1">
                                    <i class="bi bi-envelope text-muted me-2"></i>
                                    <span class="small">{{ company.email|default('Non renseigné') }}</span>
                                </div>
                                <div class="col-md-6 mb-1 text-md-end">
                                    <i class="bi bi-telephone text-muted me-2"></i>
                                    <span class="small">{{ company.phone|default('Non renseigné') }}</span>
                                </div>
                            </div>

                            <hr class="mt-3">

                            {# FOOTER DE LA CARD #}
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="text-muted" style="font-size: 0.7rem;">
                                    Inscrit le : <strong>{{ company.createdAt|date('d/m/Y') }}</strong>
                                </span>
                                <a href="{{ path('app_god_company_add_user', {'id': company.id}) }}" class="btn btn-sm btn-link text-decoration-none p-0 fw-bold">
                                    <i class="bi bi-person-badge me-1"></i>Créer un admin client
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="card shadow-sm border-0 p-5">
                        <i class="bi bi-building-add fs-1 text-muted mb-3"></i>
                        <p class="h5 text-muted">Aucune entreprise sur la plateforme.</p>
                        <div>
                            <a href="{{ path('app_company_new') }}" class="btn btn-primary btn-lg shadow">
                                <i class="bi bi-rocket-takeoff me-2"></i>Créer le premier client
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
