{# templates/company/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Paramètres : {{ company.name }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        {# Fil d'ariane pour la structure #}
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-light p-2 rounded shadow-sm small">
                <li class="breadcrumb-item"><a href="{{ path('app_company_index') }}">Entreprises</a></li>
                <li class="breadcrumb-item active">Configuration de la structure</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                        <h1 class="h4 mb-0 fw-bold">
                            <i class="bi bi-building text-primary me-2"></i>Informations de l'entreprise
                        </h1>

                        {# Suppression si nécessaire, souvent utile même pour l'entreprise #}
                        {{ include('company/_delete_form.html.twig') }}
                    </div>

                    <div class="card-body p-4">
                        <p class="text-muted small mb-4">
                            Modifiez ici les coordonnées et les informations légales qui apparaîtront sur vos rapports de maintenance.
                        </p>

                        {# Inclusion du formulaire #}
                        {{ include('company/_form.html.twig', {'button_label': 'Mettre à jour le profil'}) }}

                        <hr class="my-4">

                        <div class="d-flex justify-content-start">
                            <a href="{{ path('app_company_index') }}" class="btn btn-link text-muted text-decoration-none">
                                <i class="bi bi-arrow-left"></i> Annuler et revenir
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
