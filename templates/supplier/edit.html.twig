{% extends 'base.html.twig' %}

{% block title %}Modifier {{ supplier.name }}{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 900px;">
    {# Fil d'ariane pour la navigation rapide #}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="{{ path('app_supplier_index') }}">Fournisseurs</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_supplier_show', {id: supplier.id}) }}">{{ supplier.name }}</a></li>
            <li class="breadcrumb-item active">Modification</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0 fw-bold text-dark">
            <i class="bi bi-pencil-square text-warning me-2"></i>Modifier le partenaire
        </h1>

        {# On place la suppression en haut à droite, discrète mais accessible #}
        {{ include('supplier/_delete_form.html.twig') }}
    </div>

    {# On réutilise notre super formulaire #}
    {{ include('supplier/_form.html.twig', {'button_label': 'Mettre à jour les informations'}) }}

    <div class="mt-3 text-center">
        <a href="{{ path('app_supplier_index') }}" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left"></i> Retourner à la liste sans modifier
        </a>
    </div>
</div>
{% endblock %}
