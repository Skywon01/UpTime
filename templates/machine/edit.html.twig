{# templates/machine/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier {{ machine.name }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        {# Fil d'ariane pour le contexte #}
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-light p-2 rounded shadow-sm small">
                <li class="breadcrumb-item"><a href="{{ path('app_machine_index') }}">Parc Machines</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_machine_show', {id: machine.id}) }}">{{ machine.name }}</a></li>
                <li class="breadcrumb-item active">Configuration</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h1 class="h4 mb-0 fw-bold">
                            <i class="bi bi-gear-wide-connected text-primary me-2"></i>Modifier la machine
                        </h1>

                        {# Suppression placée discrètement dans le header #}
                        {{ include('machine/_delete_form.html.twig') }}
                    </div>

                    <div class="card-body p-4">
                        {# Inclusion du formulaire avec le label français #}
                        {{ include('machine/_form.html.twig', {'button_label': 'Enregistrer les paramètres'}) }}

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a href="{{ path('app_machine_index') }}" class="btn btn-link text-muted text-decoration-none">
                                <i class="bi bi-arrow-left"></i> Retour au parc
                            </a>
                            <small class="text-muted italic">ID Machine: #{{ machine.id }}</small>
                        </div>
                    </div>
                </div>

                {# Petit rappel visuel en bas de page #}
                <div class="mt-3 text-center">
                    <p class="small text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Les modifications impactent directement le calcul des coûts de maintenance.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
