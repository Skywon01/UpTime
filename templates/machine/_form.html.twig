{{ form_start(form) }}
<div class="card border-0 shadow-sm p-4">
    <div class="row">
        {# Section Technique #}
        <div class="col-md-7 border-end">
            <h5 class="mb-4 text-primary"><i class="bi bi-gear-wide-connected me-2"></i>Fiche Technique</h5>
            <div class="mb-3">
                {{ form_row(form.name, {'label': 'Nom de la machine', 'attr': {'placeholder': 'Ex: Presse Hydraulique n°4'}}) }}
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(form.status, {'label': 'État initial'}) }}
                </div>
                {# Si tu as un champ type ou marque, il irait ici #}
            </div>
        </div>

        {# Section Maintenance #}
        <div class="col-md-5 ps-md-4">
            <h5 class="mb-4 text-primary"><i class="bi bi-calendar-check me-2"></i>Planification</h5>
            <div class="alert alert-info py-2 small">
                <i class="bi bi-info-circle me-1"></i> Définissez la date de la prochaine révision préventive.
            </div>
            <div class="mb-3">
                {{ form_row(form.nextMaintenanceAt, {'label': 'Prochaine maintenance'}) }}
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary btn-lg flex-grow-1 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Mettre en service
        </button>
        <a href="{{ path('app_machine_index') }}" class="btn btn-outline-secondary btn-lg">Annuler</a>
    </div>
</div>

{{ form_rest(form) }}
{{ form_end(form) }}
